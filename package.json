{
  "name": "castellan",
  "version": "0.0.0",
  "description": "Beta. Lightweight deployment control and monitoring for docker-compose. One sidecar — polls registries, rolling restarts with health verification, automatic rollback, and a built-in dashboard.",
  "keywords": [
    "docker",
    "docker-compose",
    "watchtower",
    "deployment",
    "ecr",
    "ghcr",
    "docker-hub",
    "rollback",
    "sidecar",
    "lightweight",
    "containers",
    "devops",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/logfoxai/castellan.git"
  },
  "homepage": "https://github.com/logfoxai/castellan",
  "license": "MIT",
  "author": "Marc H. Weiner <mhweiner234@gmail.com>",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "!dist/**/*.spec.*",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "castellan": "dist/index.js"
  },
  "workspaces": [
    "ui"
  ],
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc && npm run build:ui",
    "build:ui": "npm run build -w ui",
    "build:compile": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "test": "c8 kizu -f 'src/**/*.spec.ts' && c8 report -r text -r html",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "screenshots": "npm run build:ui && node scripts/capture-screenshots.mjs",
    "validate": "npm run build && npm run lint && npm test"
  },
  "dependencies": {
    "@aws-sdk/client-ecr": "3.996.0",
    "date-fns": "3.6.0",
    "dockerode": "4.0.2",
    "express": "4.18.2",
    "js-yaml": "5.2.1"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "@types/express": "4.17.17",
    "@types/js-yaml": "4.0.9",
    "@types/node": "20.17.22",
    "c8": "11.0.0",
    "eslint": "10.0.2",
    "kizu": "5.1.0",
    "playwright": "1.61.1",
    "tsx": "4.20.5",
    "typescript": "5.8.3",
    "typescript-eslint": "8.56.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
