{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "src/**/*.spec.ts",
        "scripts/*.{mjs,js,ts}"
      ],
      "project": [
        "src/**/*.ts",
        "scripts/**/*.{mjs,js,ts}"
      ],
      "ignoreDependencies": [
      ],
      "ignoreBinaries": [
        "report"
      ]
    },
    "ui": {
      "project": [
        "src/**/*.{ts,tsx}"
      ]
    }
  }
}
